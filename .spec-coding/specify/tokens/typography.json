{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "PICO-UISet Typography Tokens (placeholder values)",
  "typography": {
    "heading": {
      "xl": {
        "$value": { "fontSize": 32, "fontWeight": 700, "lineHeight": 1.3 },
        "$type": "typography"
      },
      "lg": {
        "$value": { "fontSize": 24, "fontWeight": 700, "lineHeight": 1.3 },
        "$type": "typography"
      },
      "md": {
        "$value": { "fontSize": 20, "fontWeight": 600, "lineHeight": 1.4 },
        "$type": "typography"
      },
      "sm": {
        "$value": { "fontSize": 16, "fontWeight": 600, "lineHeight": 1.4 },
        "$type": "typography"
      }
    },
    "body": {
      "lg": {
        "$value": { "fontSize": 16, "fontWeight": 400, "lineHeight": 1.5 },
        "$type": "typography"
      },
      "md": {
        "$value": { "fontSize": 14, "fontWeight": 400, "lineHeight": 1.5 },
        "$type": "typography"
      }
    },
    "caption": {
      "md": {
        "$value": { "fontSize": 12, "fontWeight": 400, "lineHeight": 1.4 },
        "$type": "typography"
      },
      "sm": {
        "$value": { "fontSize": 10, "fontWeight": 400, "lineHeight": 1.4 },
        "$type": "typography"
      }
    }
  }
}
